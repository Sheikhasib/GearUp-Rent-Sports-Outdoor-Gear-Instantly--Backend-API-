            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"gearItemId\": \"e5e59e1b-38df-49f9-a029-b64077330dba\",\r\n  \"startDate\": \"2026-07-13T00:00:00.000Z\",\r\n  \"endDate\": \"2026-07-16T00:00:00.000Z\",\r\n  \"quantity\": 1\r\n}",
              "options": {
