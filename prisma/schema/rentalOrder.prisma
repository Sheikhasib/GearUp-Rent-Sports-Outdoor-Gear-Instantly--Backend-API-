model RentalOrder {
  id          String            @id @default(uuid())
  customerId  String
  gearItemId  String
  startDate   DateTime
  endDate     DateTime
  quantity    Int               @default(1)
  totalPrice  Decimal           @db.Decimal(10, 2)
  status      RentalOrderStatus @default(PLACED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer User      @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Cascade)
  gearItem GearItem  @relation(fields: [gearItemId], references: [id])
  payments Payment[]
  review   Review?

  @@index([customerId])
  @@index([gearItemId])
  @@index([status, createdAt])
  @@map("rental_orders")
}